{
	"name": "obsidian-spaced-repetition-scheduler",
	"version": "0.3.19",
	"description": "Spaced repetition scheduler for Obsidian with SM-2 algorithm and AI quiz generation",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"typecheck": "tsc -noEmit -skipLibCheck"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"spaced-repetition",
		"srs",
		"sm2",
		"flashcards",
		"learning",
		"ai",
		"quiz"
	],
	"author": "eohjun",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.41.1",
		"builtin-modules": "^5.0.0",
		"esbuild": "^0.27.2",
		"obsidian": "^1.11.0",
		"obsidian-llm-shared": "github:eohjun/obsidian-llm-shared#v1.3.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.2"
	}
}
